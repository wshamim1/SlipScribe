# Database
DATABASE_URL=postgresql://slipscribe:slipscribe_dev@localhost:5432/slipscribe

# Redis
REDIS_URL=redis://localhost:6379/0

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530

# Object Storage (MinIO for local dev)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=slipscribe
S3_SECRET_KEY=slipscribe_dev
S3_BUCKET=slipscribe-receipts
S3_REGION=us-east-1

# LLM Providers (add your keys)
OPENAI_API_KEY=sk-your-key-here
GROQ_API_KEY=gsk_your-key-here
MISTRAL_API_KEY=your-key-here

# Default LLM provider
DEFAULT_LLM_PROVIDER=groq

# JWT Secret
JWT_SECRET=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Application
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# CORS
FRONTEND_URL=http://localhost:5173

# File Upload
MAX_FILE_SIZE_MB=10
ALLOWED_EXTENSIONS=jpg,jpeg,png,heic,pdf

# Worker
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
